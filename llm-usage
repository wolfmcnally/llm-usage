#!/usr/bin/env python3
"""
llm-usage — terminal dashboard for Anthropic + OpenAI subscription rate limits.

Pulls the same numbers Claude Code's `/usage` and Codex CLI report, sized to the
current terminal. Each row shows:
    colored bar  = % of the limit consumed
    ▼ above the bar = % of the time window elapsed (i.e. *now*)
The relationship between the two is the actual signal, and the ▼ is colored
to match the over/under/on-pace verdict:
    bar ends past the ▼   → over-pace (red ▼), will hit the limit early
    bar ends before the ▼ → under-pace (green ▼), headroom available
    bar ends under the ▼  → on-pace (white ▼)

Tokens are loaded in this order:

  Anthropic OAuth:
      1. $CLAUDE_CODE_OAUTH_TOKEN
      2. macOS Keychain entry "Claude Code-credentials"
      3. ~/.claude/.credentials.json

  OpenAI/Codex OAuth:
      1. $CODEX_OAUTH_TOKEN
      2. ~/.codex/auth.json

Token expiry is reported for both providers: Anthropic from the credential
store's expiresAt, OpenAI from the access token's JWT `exp` claim (decoded
locally, never verified — inspection only).

Each provider section renders independently: a missing token, expired
credential, network failure, or API error for one provider degrades to an
inline error line in that section while the other still renders fully.

Exit codes: 0 = both providers OK, 1 = one provider failed, 2 = both failed.

Caching: each successful API response is cached on disk per provider, and a
subsequent run within the TTL (default 600s = 10 minutes) is served from that
cache without touching the network — so the real endpoints are hit at most once
every ten minutes no matter how often you run this. A 429 (rate-limit) response
is *negatively* cached for a longer window (default 1200s = 20 minutes): once a
provider says we're rate-limited, no new call is made for that window, so
re-running the tool won't keep poking a limited endpoint — it just reports the
backoff and how long remains. Any other failure (401, 5xx, network) is never
cached and retries on the next run. When a section is served from cache it's
annotated with the cache age (or the 429 backoff remaining). Override the
success window with LLM_USAGE_CACHE_TTL and the 429 window with
LLM_USAGE_RATE_LIMIT_TTL (seconds; CACHE_TTL=0 disables caching entirely), or
bypass for a single run with --fresh / --no-cache. Cache lives under
$XDG_CACHE_HOME/llm-usage (default ~/.cache/llm-usage).

No third-party dependencies — stdlib only. The provider SDKs do not expose
these endpoints; both vendor CLIs hit them directly, and so do we.
"""

from __future__ import annotations

import base64
import json
import locale
import os
import re
import shutil
import subprocess
import sys
import time
import urllib.error
import urllib.request
from datetime import datetime, timezone
from typing import Any

# ---------------------------------------------------------------- ANSI ----

RESET = "\033[0m"
BOLD = "\033[1m"
DIM = "\033[2m"


def fg256(n: int) -> str:
    return f"\033[38;5;{n}m"


WHITE = "\033[97m"
DIM_GRAY = fg256(238)
SUB_FG = fg256(245)
RULE_FG = fg256(240)


def color_for_pct(p: float) -> str:
    if p < 50:
        return fg256(78)   # green
    if p < 75:
        return fg256(186)  # yellow
    if p < 90:
        return fg256(214)  # orange
    return fg256(203)      # red


def visible_len(s: str) -> int:
    return len(re.sub(r"\033\[[0-9;]*m", "", s))


ANSI_RE = re.compile(r"\033\[([0-9;]*)m")


def clip_ansi(s: str, width: int) -> str:
    """Clip a string to a display width without counting SGR escapes."""
    if width <= 0:
        return ""
    if visible_len(s) <= width:
        return s

    out = []
    col = 0
    pos = 0
    clipped = False
    for m in ANSI_RE.finditer(s):
        text = s[pos:m.start()]
        for ch in text:
            if col >= width:
                clipped = True
                break
            out.append(ch)
            col += 1
        if col < width:
            out.append(m.group(0))
        else:
            clipped = True
            break
        pos = m.end()

    if not clipped:
        for ch in s[pos:]:
            if col >= width:
                clipped = True
                break
            out.append(ch)
            col += 1

    if "\033[" in s:
        out.append(RESET)
    return "".join(out)


def fit_text(s: str, width: int) -> str:
    if width <= 0:
        return ""
    if len(s) <= width:
        return s
    if width == 1:
        return s[:1]
    return s[:width - 1] + "…"


# ----------------------------------------------------- token loaders ----

def jwt_claims(token: str | None) -> dict | None:
    """Decode a JWT payload without verification — local expiry inspection
    only, never trust-establishing."""
    if not token or token.count(".") != 2:
        return None
    payload = token.split(".")[1]
    payload += "=" * (-len(payload) % 4)
    try:
        return json.loads(base64.urlsafe_b64decode(payload))
    except Exception:
        return None


def load_anthropic_token() -> dict | None:
    if t := os.environ.get("CLAUDE_CODE_OAUTH_TOKEN"):
        return {"access_token": t, "expires_at_ms": None,
                "subscription": None, "org": None}
    user = os.environ.get("USER", "")
    if user:
        try:
            out = subprocess.check_output(
                ["security", "find-generic-password",
                 "-s", "Claude Code-credentials",
                 "-a", user, "-w"],
                stderr=subprocess.DEVNULL,
            ).decode().strip()
            d = json.loads(out)
            c = d.get("claudeAiOauth", {})
            return {
                "access_token": c.get("accessToken"),
                "expires_at_ms": c.get("expiresAt"),
                "subscription": c.get("subscriptionType"),
                "org": d.get("organizationUuid"),
            }
        except (subprocess.CalledProcessError, json.JSONDecodeError):
            pass
    p = os.path.expanduser("~/.claude/.credentials.json")
    if os.path.exists(p):
        try:
            with open(p) as f:
                d = json.load(f)
        except (OSError, json.JSONDecodeError):
            return None
        c = d.get("claudeAiOauth", {})
        return {
            "access_token": c.get("accessToken"),
            "expires_at_ms": c.get("expiresAt"),
            "subscription": c.get("subscriptionType"),
            "org": d.get("organizationUuid"),
        }
    return None


def load_codex_token() -> dict | None:
    tok: dict | None = None
    if t := os.environ.get("CODEX_OAUTH_TOKEN"):
        tok = {"access_token": t, "account_id": None}
    else:
        p = os.path.expanduser("~/.codex/auth.json")
        if os.path.exists(p):
            try:
                with open(p) as f:
                    d = json.load(f)
            except (OSError, json.JSONDecodeError):
                return None
            toks = d.get("tokens", {}) or {}
            tok = {
                "access_token": toks.get("access_token"),
                "account_id": toks.get("account_id"),
                "auth_mode": d.get("auth_mode"),
            }
    if tok:
        # Codex access tokens are JWTs; the exp claim is the OAuth expiry.
        claims = jwt_claims(tok.get("access_token")) or {}
        exp = claims.get("exp")
        tok["expires_at_ms"] = exp * 1000 if isinstance(exp, (int, float)) \
            else None
    return tok


# ---------------------------------------------------------------- HTTP ----

def http_get_json(url: str, headers: dict, timeout: int = 15
                  ) -> tuple[int | None, Any]:
    req = urllib.request.Request(url, method="GET", headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=timeout) as r:
            return r.status, json.loads(r.read().decode())
    except urllib.error.HTTPError as e:
        try:
            body = json.loads(e.read().decode())
        except Exception:
            body = {"error": "http", "code": e.code}
        return e.code, body
    except Exception as e:
        return None, {"error": str(e)}


def fetch_anthropic(tok: dict) -> tuple[int | None, Any]:
    return http_get_json(
        "https://api.anthropic.com/api/oauth/usage",
        {
            "Authorization": f"Bearer {tok['access_token']}",
            "User-Agent": "claude-cli/1.0 (external, cli)",
            "anthropic-beta": "oauth-2025-04-20",
        },
    )


def fetch_codex(tok: dict) -> tuple[int | None, Any]:
    headers = {
        "Authorization": f"Bearer {tok['access_token']}",
        "User-Agent": "codex_cli_rs/0.45.0 (macOS; arm64)",
        "Originator": "codex_cli_rs",
        "Accept": "application/json",
    }
    if tok.get("account_id"):
        headers["Chatgpt-Account-Id"] = tok["account_id"]
    return http_get_json(
        "https://chatgpt.com/backend-api/wham/usage", headers)


# --------------------------------------------------------------- cache ----
#
# The undocumented usage endpoints are rate-limited and return 429s under load,
# so we hit them at most once per TTL window per provider. Two TTLs apply:
#
#   * Success (HTTP 200): cached for cache_ttl() (default 10 minutes). Any run
#     within the window reuses the response without a network call.
#   * Rate-limit (HTTP 429): NEGATIVELY cached for rate_limit_ttl() (default
#     20 minutes). Once we're told we're rate-limited, we make no new call for
#     the whole negative window — repeatedly running the tool won't keep poking
#     a limited endpoint and prolonging the block; it just reports the backoff.
#
# Any other failure (401, 5xx, network error) is NOT cached, so it retries on
# the very next run. Both the TUI and --json paths share the cache via
# cached_fetch(). --fresh/--no-cache (or LLM_USAGE_NO_CACHE) bypass reads;
# LLM_USAGE_CACHE_TTL=0 disables caching entirely.

DEFAULT_CACHE_TTL = 600        # seconds — success: "once per ten minutes"
DEFAULT_RATE_LIMIT_TTL = 1200  # seconds — 429 backoff: "no new call for 20 min"
DEFAULT_TUI_RETRY_SECONDS = 60
TUI_REPAINT_SECONDS = 60
_CACHE_READ_BYPASS = False     # set by --fresh/--no-cache or env


def _caching_off() -> bool:
    """True when cache reads and writes are disabled by TTL configuration."""
    raw = os.environ.get("LLM_USAGE_CACHE_TTL")
    if raw is not None:
        try:
            return int(raw) <= 0
        except ValueError:
            return False
    return False


def cache_ttl() -> int:
    """Success-cache TTL in seconds; 0 means caching is disabled."""
    if _caching_off():
        return 0
    raw = os.environ.get("LLM_USAGE_CACHE_TTL")
    if raw is None:
        return DEFAULT_CACHE_TTL
    try:
        return int(raw)
    except ValueError:
        return DEFAULT_CACHE_TTL


def rate_limit_ttl() -> int:
    """Negative-cache TTL for 429s in seconds; 0 means caching is disabled.

    Independent of cache_ttl(): a custom LLM_USAGE_CACHE_TTL changes only the
    success window, while the 429 backoff stays at its own default unless
    LLM_USAGE_RATE_LIMIT_TTL is set.
    """
    if _caching_off():
        return 0
    raw = os.environ.get("LLM_USAGE_RATE_LIMIT_TTL")
    if raw is None:
        return DEFAULT_RATE_LIMIT_TTL
    try:
        v = int(raw)
        return v if v > 0 else DEFAULT_RATE_LIMIT_TTL
    except ValueError:
        return DEFAULT_RATE_LIMIT_TTL


def _cache_dir() -> str:
    base = os.environ.get("XDG_CACHE_HOME") or os.path.expanduser("~/.cache")
    return os.path.join(base, "llm-usage")


def _cache_path(provider: str) -> str:
    return os.path.join(_cache_dir(), f"{provider}.json")


def cache_read(provider: str) -> tuple[int | None, Any, float] | None:
    """Return (code, body, age_seconds) for a fresh cache entry, else None.

    The TTL applied depends on the cached status: a 429 entry lives for
    rate_limit_ttl() (negative cache / backoff), anything else (a 200) for
    cache_ttl().
    """
    if _CACHE_READ_BYPASS or _caching_off():
        return None
    try:
        with open(_cache_path(provider)) as f:
            d = json.load(f)
    except (OSError, json.JSONDecodeError):
        return None
    ts = d.get("ts")
    if not isinstance(ts, (int, float)):
        return None
    code = d.get("code")
    ttl = rate_limit_ttl() if code == 429 else cache_ttl()
    if ttl <= 0:
        return None
    age = time.time() - ts
    if age < 0 or age > ttl:
        return None
    return code, d.get("body"), age


def cache_write(provider: str, code: int | None, body: Any) -> None:
    """Persist a fetch result. Best-effort: cache I/O never breaks a run."""
    path = _cache_path(provider)
    tmp = f"{path}.{os.getpid()}.tmp"
    try:
        os.makedirs(_cache_dir(), exist_ok=True)
        with open(tmp, "w") as f:
            json.dump({"ts": time.time(), "code": code, "body": body}, f)
        os.replace(tmp, path)  # atomic — concurrent runs never see a partial
    except OSError:
        try:
            os.unlink(tmp)
        except OSError:
            pass


def cached_fetch(provider: str, fetch_fn, tok: dict
                 ) -> tuple[int | None, Any, float | None]:
    """Fetch with a per-provider TTL cache.

    Returns (code, body, cache_age): cache_age is None for a live network
    call, or the age in seconds of the served cache entry. A 200 is cached for
    the success TTL and a 429 for the (longer) rate-limit backoff TTL; any
    other status falls through to a live call next time so transient errors
    don't get pinned.
    """
    hit = cache_read(provider)
    if hit is not None:
        code, body, age = hit
        return code, body, age
    code, body = fetch_fn(tok)
    if code in (200, 429) and not _caching_off():
        cache_write(provider, code, body)
    return code, body, None


def cache_notice(code: int | None, age: float | None) -> str | None:
    """Return a dim 'served from cache' header annotation for a cached success.

    Cached 429s are surfaced by the sections' rate-limit branch instead, so
    this stays quiet for them.
    """
    if age is None or code != 200:
        return None
    return f"{DIM}[↻ cached {fmt_relative(age)} ago]{RESET}"


# ----------------------------------------------------------- bar render ----

FULL = "█"
EMPTY = "░"
NOW_MARK = "▼"


def render_bar(width: int, usage_pct: float) -> tuple[str, bool]:
    """Return (bar_string, overflow). Width is total cells."""
    width = max(width, 4)
    overflow = usage_pct > 100
    fill_cells = round(min(max(0, usage_pct), 100) / 100 * width)
    color = color_for_pct(usage_pct)
    cells = []
    for i in range(width):
        if i < fill_cells:
            cells.append(color + FULL + RESET)
        else:
            cells.append(DIM_GRAY + EMPTY + RESET)
    return "".join(cells), overflow


# ---------------------------------------------------------- time helpers ----

def parse_iso(s: str | None) -> datetime | None:
    if not s:
        return None
    if s.endswith("Z"):
        s = s[:-1] + "+00:00"
    try:
        return datetime.fromisoformat(s)
    except ValueError:
        return None


def fmt_local(dt: datetime | None) -> str:
    if not dt:
        return "—"
    return dt.astimezone().strftime("%a %b %d %H:%M %Z")


def fmt_relative(seconds: float | None) -> str:
    if seconds is None:
        return "—"
    s = int(max(0, seconds))
    d, rem = divmod(s, 86400)
    h, rem = divmod(rem, 3600)
    m, _ = divmod(rem, 60)
    if d:
        return f"{d}d {h}h"
    if h:
        return f"{h}h {m:02d}m"
    return f"{m}m"


def fmt_window(seconds: int) -> str:
    if seconds % 86400 == 0 and seconds >= 86400:
        d = seconds // 86400
        return f"{d}-day" if d > 1 else "1-day"
    if seconds % 3600 == 0:
        h = seconds // 3600
        return f"{h}-hour"
    return f"{seconds}s"


# ------------------------------------------------------------------ row ----

def label_width(width: int) -> int:
    if width < 46:
        return 10
    if width < 72:
        return 14
    return 18


def row(label: str, usage_pct: float, now_pct: float | None,
        reset_dt: datetime | None, reset_seconds: float | None,
        width: int, label_w: int | None = None) -> str:
    label_w = label_width(width) if label_w is None else label_w
    pct_str = f"{usage_pct:4.0f}%"
    min_bar = 4 if width < 46 else 8
    bar_w = max(min_bar, width - label_w - len(pct_str) - 2)
    bar, overflow = render_bar(bar_w, usage_pct)
    raw_label = fit_text(label, label_w)
    lbl = f"{BOLD}{raw_label:<{label_w}}{RESET}"
    pct_color = color_for_pct(usage_pct)
    overflow_mark = f" {fg256(203)}↑{RESET}" if overflow else "  "
    line1 = f"{lbl}{bar}{overflow_mark}{pct_color}{pct_str}{RESET}"

    line0 = ""
    pace = ""
    if now_pct is not None:
        margin = usage_pct - now_pct
        if usage_pct >= now_pct + 5:
            pace_color = fg256(203)
            verdict = "over pace"
        elif usage_pct <= now_pct - 5:
            pace_color = fg256(78)
            verdict = "under pace"
        else:
            pace_color = WHITE
            verdict = "on pace"
        if verdict == "on pace":
            pace = f"   {pace_color}≈ on pace{RESET}"
        elif width < 64:
            arrow = "↑" if verdict == "over pace" else "↓"
            pace = f"   {pace_color}{arrow} {margin:+.0f}pp{RESET}"
        else:
            arrow = "↑" if verdict == "over pace" else "↓"
            pace = f"   {pace_color}{arrow} {margin:+.0f}pp {verdict}{RESET}"
        now_idx = min(max(0, round(now_pct / 100 * bar_w)), bar_w - 1)
        line0 = " " * (label_w + now_idx) + pace_color + NOW_MARK + RESET

    parts = []
    if reset_dt and width >= 84:
        parts.append(f"resets {fmt_local(reset_dt)}")
    if reset_seconds is not None:
        parts.append(f"in {fmt_relative(reset_seconds)}")
    if now_pct is not None and width >= 58:
        parts.append(f"window {now_pct:.0f}% elapsed")
    if width < 44:
        pace = ""
    if not parts and not pace:
        return clip_ansi(line0, width) + "\n" + clip_ansi(line1, width)
    sub = SUB_FG + "  ·  ".join(parts) + RESET + pace
    line2 = f"{' ' * label_w}{sub}"
    return "\n".join([
        clip_ansi(line0, width),
        clip_ansi(line1, width),
        clip_ansi(line2, width),
    ])


# -------------------------------------------------------------- header ----

def section_header(title: str, plan: str, width: int,
                   notices: list[str | None] | None = None) -> list[str]:
    left_parts = [f"{BOLD}{title}{RESET}"]
    if plan and width >= 48:
        left_parts.append(f"{DIM}{plan}{RESET}")
    notice_parts = [n for n in (notices or []) if n]
    now_str = datetime.now().astimezone().strftime("%a %b %d %H:%M %Z")
    if width < 48:
        left_parts.extend(notice_parts)
        left = "  ".join(left_parts)
        line = left
    else:
        max_left = max(0, width - len(now_str) - 1)
        left = "  ".join(left_parts)
        for notice in notice_parts:
            candidate = f"{left}  {notice}"
            if visible_len(candidate) <= max_left:
                left = candidate
        pad = width - visible_len(left) - len(now_str)
        if pad < 1:
            left = clip_ansi(left, max(0, width - len(now_str) - 1))
            pad = width - visible_len(left) - len(now_str)
        if pad < 1:
            line = left
        else:
            line = left + " " * pad + DIM + now_str + RESET
    return [clip_ansi(line, width), RULE_FG + "─" * width + RESET]


def warn_line(msg: str) -> str:
    return f"  {fg256(203)}✖ {msg}{RESET}"


def rate_limit_notice(age: float | None) -> str:
    """Report a 429 backoff. age=None means we hit it live this render."""
    if age is None:
        return (f"{fg256(214)}[● rate limited (429), retry in "
                f"{fmt_relative(rate_limit_ttl())}]{RESET}")
    remaining = max(0.0, rate_limit_ttl() - age)
    return (f"{fg256(214)}[● rate limited (429), retry in "
            f"{fmt_relative(remaining)}]{RESET}")


def token_expiry_notice(expires_at_ms: int | None) -> tuple[str | None, bool]:
    """Return an OAuth-expiry header annotation and whether it is expired."""
    if expires_at_ms is None:
        return None, False
    exp = datetime.fromtimestamp(expires_at_ms / 1000, tz=timezone.utc)
    secs = (exp - datetime.now(timezone.utc)).total_seconds()
    if secs <= 0:
        return (f"{fg256(203)}[✖ OAuth expired {fmt_relative(-secs)} "
                f"ago]{RESET}", True)
    if secs > 4 * 3600:
        return None, False
    if secs < 3600:
        color = fg256(203)
    else:
        color = fg256(214)
    return (f"{color}[⚠ OAuth expires in {fmt_relative(secs)}]{RESET}", False)


# ------------------------------------------------------------- sections ----

def next_data_refresh_deadline(code: int | None, age: float | None,
                               loaded_at: float) -> float:
    if code == 200:
        ttl = cache_ttl()
    elif code == 429:
        ttl = rate_limit_ttl()
    else:
        return loaded_at + DEFAULT_TUI_RETRY_SECONDS
    if ttl <= 0:
        return loaded_at + DEFAULT_TUI_RETRY_SECONDS
    return loaded_at + max(1.0, ttl - (age or 0.0))


def snapshot_elapsed(snapshot: dict) -> float:
    return max(0.0, time.time() - float(snapshot.get("loaded_at", time.time())))


def displayed_cache_age(snapshot: dict, include_live_429: bool = False
                        ) -> float | None:
    age = snapshot.get("age")
    if age is not None:
        return float(age) + snapshot_elapsed(snapshot)
    if include_live_429 and snapshot.get("code") == 429:
        return snapshot_elapsed(snapshot)
    return None


def anthropic_snapshot() -> dict:
    loaded_at = time.time()
    tok = load_anthropic_token()
    if not tok or not tok.get("access_token"):
        return {"provider": "anthropic", "token": None, "code": None,
                "body": None, "age": None, "loaded_at": loaded_at,
                "deadline": loaded_at + DEFAULT_TUI_RETRY_SECONDS}

    code, body, age = cached_fetch("anthropic", fetch_anthropic, tok)
    return {"provider": "anthropic", "token": tok, "code": code,
            "body": body, "age": age, "loaded_at": loaded_at,
            "deadline": next_data_refresh_deadline(code, age, loaded_at)}


def render_anthropic_section(snapshot: dict, width: int) -> tuple[list[str], bool]:
    """Render the Anthropic section. Returns lines plus success state."""
    lines = []
    tok = snapshot.get("token")
    if not tok or not tok.get("access_token"):
        lines.extend(section_header("ANTHROPIC", "Claude", width))
        lines.append(warn_line("no OAuth token "
                               "(set $CLAUDE_CODE_OAUTH_TOKEN or run `claude` "
                               "to login)"))
        return [clip_ansi(line, width) for line in lines], False

    code = snapshot.get("code")
    body = snapshot.get("body") or {}
    expiry, expired = token_expiry_notice(tok.get("expires_at_ms"))
    if code == 429:
        status = rate_limit_notice(
            displayed_cache_age(snapshot, include_live_429=True))
    else:
        status = cache_notice(code, displayed_cache_age(snapshot))
    plan_label = (tok.get("subscription") or "").title()
    lines.extend(section_header(
        "ANTHROPIC",
        f"Claude {plan_label} Plan" if plan_label else "Claude",
        width,
        [status, expiry],
    ))
    if code == 401:
        lines.append(warn_line("token rejected (401)"
                               + (" — expired" if expired else "")
                               + "; run `claude` to refresh"))
        return [clip_ansi(line, width) for line in lines], False
    if code == 429:
        return [clip_ansi(line, width) for line in lines], False
    if code != 200:
        lines.append(warn_line(f"API error {code}: {json.dumps(body)[:200]}"))
        return [clip_ansi(line, width) for line in lines], False

    now = datetime.now(timezone.utc)
    bands = [
        ("7-day overall", body.get("seven_day"), 7 * 86400),
        ("5-hour", body.get("five_hour"), 5 * 3600),
        ("7-day Sonnet", body.get("seven_day_sonnet"), 7 * 86400),
        ("7-day Opus", body.get("seven_day_opus"), 7 * 86400),
        ("7-day OAuth apps", body.get("seven_day_oauth_apps"), 7 * 86400),
        ("7-day cowork", body.get("seven_day_cowork"), 7 * 86400),
    ]
    printed = 0
    for label, data, window_s in bands:
        if not data:
            continue
        usage = float(data.get("utilization", 0))
        reset_dt = parse_iso(data.get("resets_at"))
        if reset_dt:
            rem = (reset_dt - now).total_seconds()
            now_pct = max(0.0, min(100.0, (window_s - rem) / window_s * 100))
        else:
            rem = None
            now_pct = None
        lines.extend(row(label, usage, now_pct, reset_dt, rem, width).splitlines())
        printed += 1
    if not printed:
        lines.append(f"  {DIM}(no usage data){RESET}")
    return [clip_ansi(line, width) for line in lines], True


def openai_snapshot() -> dict:
    loaded_at = time.time()
    tok = load_codex_token()
    if not tok or not tok.get("access_token"):
        return {"provider": "openai", "token": None, "code": None,
                "body": None, "age": None, "loaded_at": loaded_at,
                "deadline": loaded_at + DEFAULT_TUI_RETRY_SECONDS}

    code, body, age = cached_fetch("openai", fetch_codex, tok)
    return {"provider": "openai", "token": tok, "code": code,
            "body": body, "age": age, "loaded_at": loaded_at,
            "deadline": next_data_refresh_deadline(code, age, loaded_at)}


def adjusted_openai_reset_seconds(snapshot: dict, window: dict
                                  ) -> float | None:
    reset_at = window.get("reset_at")
    if reset_at:
        reset_dt = datetime.fromtimestamp(reset_at, tz=timezone.utc)
        return max(0.0, (reset_dt - datetime.now(timezone.utc)).total_seconds())
    rem_s = window.get("reset_after_seconds")
    if rem_s is None:
        return None
    return max(0.0, float(rem_s) - snapshot_elapsed(snapshot))


def render_openai_section(snapshot: dict, width: int) -> tuple[list[str], bool]:
    """Render the OpenAI section. Returns lines plus success state."""
    lines = []
    tok = snapshot.get("token")
    if not tok or not tok.get("access_token"):
        lines.extend(section_header("OPENAI", "ChatGPT", width))
        lines.append(warn_line("no OAuth token "
                               "(set $CODEX_OAUTH_TOKEN or run `codex` "
                               "to login)"))
        return [clip_ansi(line, width) for line in lines], False

    code = snapshot.get("code")
    body = snapshot.get("body") or {}
    plan = (body.get("plan_type") or "").title() if code == 200 else ""
    expiry, expired = token_expiry_notice(tok.get("expires_at_ms"))
    if code == 429:
        status = rate_limit_notice(
            displayed_cache_age(snapshot, include_live_429=True))
    else:
        status = cache_notice(code, displayed_cache_age(snapshot))
    lines.extend(section_header(
        "OPENAI",
        f"ChatGPT {plan} Plan" if plan else "ChatGPT",
        width,
        [status, expiry],
    ))

    if code == 401:
        lines.append(warn_line("token rejected (401)"
                               + (" — expired" if expired else "")
                               + "; run `codex` to refresh"))
        return [clip_ansi(line, width) for line in lines], False
    if code == 429:
        return [clip_ansi(line, width) for line in lines], False
    if code != 200:
        lines.append(warn_line(f"API error {code}: {json.dumps(body)[:200]}"))
        return [clip_ansi(line, width) for line in lines], False

    rl = body.get("rate_limit") or {}
    if rl.get("limit_reached"):
        lines.append(f"  {fg256(203)}● limit reached — requests will be rejected"
                     f"{RESET}")
    elif not rl.get("allowed", True):
        lines.append(f"  {fg256(214)}⚠ requests not currently allowed{RESET}")

    printed = 0
    # Weekly (secondary) window first — it's the limit that matters most.
    for key, default_label in [
        ("secondary_window", "secondary"),
        ("primary_window", "primary"),
    ]:
        w = rl.get(key)
        if not w:
            continue
        usage = float(w.get("used_percent", 0))
        wnd_s = w.get("limit_window_seconds")
        rem_s = adjusted_openai_reset_seconds(snapshot, w)
        if wnd_s and rem_s is not None:
            now_pct = max(0.0, min(100.0,
                                   (wnd_s - rem_s) / wnd_s * 100))
        else:
            now_pct = None
        reset_at = w.get("reset_at")
        reset_dt = (datetime.fromtimestamp(reset_at, tz=timezone.utc)
                    if reset_at else None)
        label = fmt_window(wnd_s) if wnd_s else default_label
        if key == "secondary_window":
            label = f"{label} (weekly)"
        lines.extend(row(label, usage, now_pct, reset_dt, rem_s, width).splitlines())
        printed += 1
    if not printed:
        lines.append(f"  {DIM}(no usage data){RESET}")
    return [clip_ansi(line, width) for line in lines], True


# ------------------------------------------------------------ json output ----
#
# `--json` emits a machine-readable snapshot for schedulers (e.g. bin/checkpoint)
# that route work to whichever subscription has the most headroom. Both providers
# are normalized to a uniform shape: each relevant window reports `utilization`
# as a percent (0-100) plus seconds-until-reset. The TUI path is untouched.

def _anthropic_json() -> dict:
    tok = load_anthropic_token()
    if not tok or not tok.get("access_token"):
        return {"ok": False, "error": "no OAuth token", "windows": {},
                "cached": False, "cache_age_seconds": None}
    code, a, age = cached_fetch("anthropic", fetch_anthropic, tok)
    if code != 200:
        err = "rate limited (429)" if code == 429 else f"API error {code}"
        return {"ok": False, "error": err, "windows": {},
                "rate_limited": code == 429,
                "cached": age is not None, "cache_age_seconds": age}
    now = datetime.now(timezone.utc)
    windows: dict[str, Any] = {}
    for key in ("seven_day", "five_hour"):
        d = a.get(key)
        if not d:
            continue
        reset_dt = parse_iso(d.get("resets_at"))
        rem = (reset_dt - now).total_seconds() if reset_dt else None
        windows[key] = {
            "utilization": float(d.get("utilization", 0)),
            "resets_at": d.get("resets_at"),
            "reset_seconds": rem,
        }
    return {"ok": True, "error": None,
            "subscription": tok.get("subscription"), "windows": windows,
            "cached": age is not None, "cache_age_seconds": age}


def _openai_json() -> dict:
    tok = load_codex_token()
    if not tok or not tok.get("access_token"):
        return {"ok": False, "error": "no OAuth token", "windows": {},
                "cached": False, "cache_age_seconds": None}
    code, o, age = cached_fetch("openai", fetch_codex, tok)
    if code != 200:
        err = "rate limited (429)" if code == 429 else f"API error {code}"
        return {"ok": False, "error": err, "windows": {},
                "rate_limited": code == 429,
                "cached": age is not None, "cache_age_seconds": age}
    rl = o.get("rate_limit") or {}
    windows: dict[str, Any] = {}
    for key in ("secondary_window", "primary_window"):
        w = rl.get(key)
        if not w:
            continue
        windows[key] = {
            "utilization": float(w.get("used_percent", 0)),
            "reset_seconds": w.get("reset_after_seconds"),
            "reset_at": w.get("reset_at"),
        }
    return {"ok": True, "error": None,
            "plan": o.get("plan_type"),
            "limit_reached": bool(rl.get("limit_reached")),
            "windows": windows,
            "cached": age is not None, "cache_age_seconds": age}


def emit_json() -> int:
    a = _anthropic_json()
    o = _openai_json()
    print(json.dumps({"anthropic": a, "openai": o}, indent=2))
    return 0 if (a["ok"] and o["ok"]) else (1 if (a["ok"] or o["ok"]) else 2)


# ------------------------------------------------------------ dashboard ----

def load_dashboard_snapshot() -> dict:
    a = anthropic_snapshot()
    o = openai_snapshot()
    deadline = min(float(a["deadline"]), float(o["deadline"]))
    return {"anthropic": a, "openai": o, "deadline": deadline}


def display_width(columns: int, clamp: bool) -> int:
    if clamp:
        return min(max(columns, 60), 140)
    return max(20, columns)


def dashboard_exit_code(a_ok: bool, o_ok: bool) -> int:
    if a_ok and o_ok:
        return 0
    return 1 if (a_ok or o_ok) else 2


def legend_lines() -> list[str]:
    legend_used = (
        f"{DIM}Used:{RESET} "
        f"{fg256(78)}{FULL}{RESET} ok  "
        f"{fg256(186)}{FULL}{RESET} 50%  "
        f"{fg256(214)}{FULL}{RESET} 75%  "
        f"{fg256(203)}{FULL}{RESET} 90%"
    )
    legend_pace = (
        f"{DIM}Pace:{RESET} "
        f"{fg256(78)}{NOW_MARK}{RESET} under  "
        f"{WHITE}{NOW_MARK}{RESET} on  "
        f"{fg256(203)}{NOW_MARK}{RESET} over"
    )
    return [legend_used, legend_pace]


def render_dashboard_snapshot(snapshot: dict, columns: int,
                              clamp_width: bool) -> tuple[list[str], int]:
    width = display_width(columns, clamp_width)
    lines = []
    a_lines, a_ok = render_anthropic_section(snapshot["anthropic"], width)
    lines.extend(a_lines)
    lines.extend(["", RULE_FG + "═" * width + RESET, ""])
    o_lines, o_ok = render_openai_section(snapshot["openai"], width)
    lines.extend(o_lines)
    lines.append("")
    lines.extend(legend_lines())
    lines.append("")
    return [clip_ansi(line, width) for line in lines], dashboard_exit_code(a_ok, o_ok)


def render_dashboard(columns: int, clamp_width: bool
                     ) -> tuple[dict, list[str], int]:
    snapshot = load_dashboard_snapshot()
    lines, exit_code = render_dashboard_snapshot(snapshot, columns, clamp_width)
    return snapshot, lines, exit_code


# ----------------------------------------------------------------- main ----

def no_cache_env() -> bool:
    return bool(os.environ.get("LLM_USAGE_NO_CACHE"))


def set_cache_read_bypass(value: bool) -> None:
    global _CACHE_READ_BYPASS
    _CACHE_READ_BYPASS = value


def parse_cache_flags(args: list[str]) -> bool:
    """Honor --fresh/--no-cache and LLM_USAGE_NO_CACHE before any fetch."""
    fresh = "--fresh" in args or "--no-cache" in args
    set_cache_read_bypass(fresh or no_cache_env())
    return fresh


def curses_color(curses_mod, color: int, pairs: dict[int, int]) -> int:
    if not curses_mod.has_colors():
        return 0
    if color == 97:
        color = 15 if curses_mod.COLORS > 15 else curses_mod.COLOR_WHITE
    elif color >= curses_mod.COLORS:
        color = {
            78: curses_mod.COLOR_GREEN,
            186: curses_mod.COLOR_YELLOW,
            214: curses_mod.COLOR_YELLOW,
            203: curses_mod.COLOR_RED,
            238: curses_mod.COLOR_WHITE,
            240: curses_mod.COLOR_WHITE,
            245: curses_mod.COLOR_WHITE,
        }.get(color, curses_mod.COLOR_WHITE)
    if color not in pairs:
        pair_id = len(pairs) + 1
        if pair_id >= curses_mod.COLOR_PAIRS:
            return 0
        try:
            curses_mod.init_pair(pair_id, color, -1)
        except curses_mod.error:
            return 0
        pairs[color] = pair_id
    return curses_mod.color_pair(pairs[color])


def apply_sgr(curses_mod, codes: list[int], style: int, color_attr: int,
              pairs: dict[int, int]) -> tuple[int, int]:
    i = 0
    if not codes:
        codes = [0]
    while i < len(codes):
        code = codes[i]
        if code == 0:
            style = 0
            color_attr = 0
        elif code == 1:
            style |= curses_mod.A_BOLD
        elif code == 2:
            style |= curses_mod.A_DIM
        elif code == 22:
            style &= ~(curses_mod.A_BOLD | curses_mod.A_DIM)
        elif code == 39:
            color_attr = 0
        elif code == 97:
            color_attr = curses_color(curses_mod, 97, pairs)
        elif code == 38 and i + 2 < len(codes) and codes[i + 1] == 5:
            color_attr = curses_color(curses_mod, codes[i + 2], pairs)
            i += 2
        i += 1
    return style, color_attr


def draw_text(stdscr, y: int, x: int, text: str, width: int, attr: int) -> int:
    if width <= 0 or not text:
        return 0
    part = text[:width]
    try:
        stdscr.addstr(y, x, part, attr)
    except Exception:
        pass
    return len(part)


def draw_ansi_line(curses_mod, stdscr, y: int, line: str, width: int,
                   pairs: dict[int, int]) -> None:
    style = 0
    color_attr = 0
    col = 0
    pos = 0
    for m in ANSI_RE.finditer(line):
        text = line[pos:m.start()]
        col += draw_text(stdscr, y, col, text, width - col,
                         style | color_attr)
        if col >= width:
            return
        raw_codes = [c for c in m.group(1).split(";") if c]
        try:
            codes = [int(c) for c in raw_codes]
        except ValueError:
            codes = [0]
        style, color_attr = apply_sgr(curses_mod, codes, style, color_attr,
                                      pairs)
        pos = m.end()
    if col < width:
        draw_text(stdscr, y, col, line[pos:], width - col, style | color_attr)


def clamp_scroll(scroll: int, line_count: int, height: int) -> int:
    return min(max(0, scroll), max(0, line_count - max(1, height)))


def draw_tui(curses_mod, stdscr, lines: list[str], scroll: int,
             pairs: dict[int, int]) -> None:
    height, width = stdscr.getmaxyx()
    stdscr.erase()
    for y in range(height):
        idx = scroll + y
        if idx >= len(lines):
            break
        draw_ansi_line(curses_mod, stdscr, y, lines[idx], width, pairs)
    stdscr.noutrefresh()
    curses_mod.doupdate()


def setup_curses(curses_mod, stdscr) -> dict[int, int]:
    stdscr.keypad(True)
    try:
        curses_mod.curs_set(0)
    except curses_mod.error:
        pass
    if curses_mod.has_colors():
        curses_mod.start_color()
        try:
            curses_mod.use_default_colors()
        except curses_mod.error:
            pass
    try:
        curses_mod.mousemask(curses_mod.ALL_MOUSE_EVENTS)
    except curses_mod.error:
        pass
    return {}


def run_tui(initial_fresh: bool) -> int:
    try:
        locale.setlocale(locale.LC_ALL, "")
    except locale.Error:
        pass
    try:
        import curses
    except ImportError:
        print("llm-usage: --tui requires the stdlib curses module",
              file=sys.stderr)
        return 2

    def _run(stdscr) -> int:
        pairs = setup_curses(curses, stdscr)
        height, width = stdscr.getmaxyx()
        snapshot, lines, exit_code = render_dashboard(width, clamp_width=False)
        if initial_fresh:
            set_cache_read_bypass(no_cache_env())
        scroll = 0
        next_data = float(snapshot["deadline"])
        next_repaint = time.time() + TUI_REPAINT_SECONDS
        draw_tui(curses, stdscr, lines, scroll, pairs)

        while True:
            now = time.time()
            if now >= next_data:
                height, width = stdscr.getmaxyx()
                snapshot, lines, exit_code = render_dashboard(
                    width, clamp_width=False)
                next_data = float(snapshot["deadline"])
                next_repaint = now + TUI_REPAINT_SECONDS
                scroll = clamp_scroll(scroll, len(lines), height)
                draw_tui(curses, stdscr, lines, scroll, pairs)
                continue
            if now >= next_repaint:
                height, width = stdscr.getmaxyx()
                lines, exit_code = render_dashboard_snapshot(
                    snapshot, width, clamp_width=False)
                next_repaint = now + TUI_REPAINT_SECONDS
                scroll = clamp_scroll(scroll, len(lines), height)
                draw_tui(curses, stdscr, lines, scroll, pairs)
                continue

            wait = min(next_data, next_repaint) - now
            stdscr.timeout(min(1000, max(50, int(wait * 1000))))
            ch = stdscr.getch()
            if ch == -1:
                continue
            if ch in (ord("q"), ord("Q"), 27):
                return exit_code
            if ch == 3:
                return 130

            height, width = stdscr.getmaxyx()
            old_scroll = scroll
            redraw = False
            if ch == curses.KEY_RESIZE:
                lines, exit_code = render_dashboard_snapshot(
                    snapshot, width, clamp_width=False)
                redraw = True
            elif ch in (curses.KEY_UP, ord("k"), ord("K")):
                scroll -= 1
            elif ch in (curses.KEY_DOWN, ord("j"), ord("J")):
                scroll += 1
            elif ch == curses.KEY_PPAGE:
                scroll -= max(1, height - 1)
            elif ch == curses.KEY_NPAGE:
                scroll += max(1, height - 1)
            elif ch == curses.KEY_HOME:
                scroll = 0
            elif ch == curses.KEY_END:
                scroll = len(lines)
            elif ch == curses.KEY_MOUSE:
                try:
                    _id, _x, _y, _z, bstate = curses.getmouse()
                except curses.error:
                    bstate = 0
                if bstate & getattr(curses, "BUTTON4_PRESSED", 0):
                    scroll -= 3
                elif bstate & getattr(curses, "BUTTON5_PRESSED", 0):
                    scroll += 3

            scroll = clamp_scroll(scroll, len(lines), height)
            if redraw or scroll != old_scroll:
                draw_tui(curses, stdscr, lines, scroll, pairs)

    try:
        return curses.wrapper(_run)
    except KeyboardInterrupt:
        return 130


def main() -> None:
    args = sys.argv[1:]
    fresh = parse_cache_flags(args)
    tui = "--tui" in args
    json_mode = "--json" in args
    if tui and json_mode:
        print("llm-usage: --tui cannot be combined with --json",
              file=sys.stderr)
        sys.exit(2)
    if json_mode:
        sys.exit(emit_json())
    if tui:
        if not sys.stdout.isatty():
            print("llm-usage: --tui requires an interactive terminal",
                  file=sys.stderr)
            sys.exit(2)
        sys.exit(run_tui(initial_fresh=fresh))

    width = shutil.get_terminal_size((100, 24)).columns
    _snapshot, lines, exit_code = render_dashboard(width, clamp_width=True)
    for line in lines:
        print(line)
    if exit_code:
        sys.exit(exit_code)


if __name__ == "__main__":
    code = 0
    try:
        main()
    except KeyboardInterrupt:
        code = 130
    except SystemExit as e:
        code = e.code if isinstance(e.code, int) else 0
    except BrokenPipeError:
        code = 141  # 128 + SIGPIPE, the conventional code
    # Flush here, inside a guard: a downstream pipe (head, less quit early)
    # closing otherwise raises an unhandled BrokenPipeError in the
    # interpreter's exit flush.
    try:
        sys.stdout.flush()
    except BrokenPipeError:
        code = 141
    if code == 141:
        os.dup2(os.open(os.devnull, os.O_WRONLY), sys.stdout.fileno())
    sys.exit(code)
